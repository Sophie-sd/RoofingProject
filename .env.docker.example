SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.docker

POSTGRES_DB=roofing
POSTGRES_USER=roofing
POSTGRES_PASSWORD=strong-password-change-me
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://roofing:strong-password-change-me@db:5432/roofing

# Domain, Droplet IP, localhost, and "web" (compose DNS / healthcheck)
ALLOWED_HOSTS=example.com,www.example.com,DROPLET_IP,127.0.0.1,localhost,web

# Before SSL use http://; after certbot switch to https://
USE_HTTPS=false
SITE_URL=http://example.com
CSRF_TRUSTED_ORIGINS=http://example.com,http://www.example.com

# TLS is terminated by nginx — keep False for Gunicorn healthchecks
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# After SSL:
# USE_HTTPS=true
# SITE_URL=https://example.com
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

HTTP_PORT=80

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
